{
	"layer":"top",
	"position":"top",
	"reload_style_on_change":true,
		
	"height":20,
  "margin-top": 5,
	"margin-left": 5,
	"margin-right":5,
	
	"modules-left":[
    "hyprland/workspaces",
    "custom/crypto",
  ],
"modules-center": [
    "battery",
		"clock#time",
    "backlight",
],
	"modules-right":[
		"custom/notification",
		"network",
		"wireplumber",
    "cpu",
    "memory",
    "hyprland/language",
    "tray",
		"custom/power"
		],
		
		"hyprland/workspaces": {
		    "all-outputs": true,
		    "format": "{icon}",
		    "format-icons": {
		        "1": "дёЂ",
		        "2": "дєЊ",
		        "3": "дё‰",
		        "4": "е››",
		        "5": "дє”",
		        "6": "е…­",
		        "7": "дёѓ",
		        "8": "е…«",
		        "9": "д№ќ",
		        "10": "еЌЃ"
		    },
		    "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
		    "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
		    "sort-by-number": true,
		    "active-only": false,
    },
	
	"wireplumber": {
		    "on-click": "pavucontrol",
		    "on-click-right": "amixer sset Master toggle 1>/dev/null",
		    "format": "{icon}  {volume}%",
		    "format-muted": "пЂ¦  Muted",
		    "format-icons": {
		        "headphone": "пЂҐ ",
		        "hands-free": "п–ђ ",
		        "headset": "п–ђ ",
		        "phone": "п‚• ",
		        "portable": "п‚• ",
		        "car": "п†№ ",
		        "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ "]
		    },
		},
        
    "network": {
        "format-wifi": "п‡«   {essid}  ",
        "format-ethernet": "пЂ’   {ifname}",
        "format-linked": "пЂ’  {ifname} (No IP)",
        "format": "пЂ’  Connected",
        "format-disconnected": "пљ”  Disconnected",
        "interval": 60,
        "on-click": "nm-connection-editor"
    },
    "clock#time": {
        "format": "{:%H:%M  %a}",
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // START CLOCK FORMAT
        "format-alt": "{:%d.%m.%Y}"
        // END CLOCK FORMAT
    },
    "custom/power":{
    	"format":"у°ђҐ",
      "on-click": "wlogout -b 6 -c 16 -r 0 -T 450 -B 450 -L 200 -R 200",
    },
    "custom/notification":{
    	"format": "у±…«",
    	"on-click": "swaync-client -t -sw"
    },

    "cpu": {
        "format": "у°Ќ› {usage}%",
        "on-click": "kitty -e btop"
    },

    "memory": {
        "format": "ої… {}%",
        "on-click": "kitty -e btop"
    },

    "hyprland/language": {
        "format": "у°ЊЊ {short}"
    },

    "custom/crypto": {
        "format": "{}",
        "interval": 600,
        "return-type": "json",
        "exec": "waybar-crypto",
        "exec-if": "command -v waybar-crypto",
        "on-click": "xdg-open https://coinmarketcap.com/"
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "battery": {
      "bat": "BATT",
      "adapter": "ACAD",
      "interval": 30,
      "format": "{capacity}% п‰Ѓ",
      "format-charging": "{capacity}% п‡¦",
      "format-plugged": "{capacity}% п‡¦",
      "format-alt": "{time} {capacity}%",
      "tooltip": true,
      "tooltip-format": "Remaining: {time}"
    },
    "backlight": {
      "device": "amdgpu_bl1",
      "format": "у°ѓџ {percent}%",
        "on-scroll-up":"brightnessctl set +1%",
        "on-scroll-down":"brightnessctl set 1%-"
    },

}
